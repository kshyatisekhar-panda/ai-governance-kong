# --- LLM provider --------------------------------------------------------
# Default provider is OpenRouter. Real keys must be added to a local .env
# file that is git-ignored. The browser must NEVER see LLM_API_KEY — only
# the server-side gateway reads it.
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-REPLACE_WITH_YOUR_OPENROUTER_KEY

# Required attribution headers for OpenRouter (safe to expose).
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=AI-Governed Customer Service Hub

# Model tiers. SMALL_MODEL is used for simple prompts; LARGE_MODEL is used
# when the smart router classifies a prompt as complex.
SMALL_MODEL=openai/gpt-4o-mini
LARGE_MODEL=openai/gpt-4o

# --- LLM path mode -------------------------------------------------------
# direct-provider | kong-ai-route | mock
# direct-provider is the current default — Express calls OpenRouter directly.
# Set to "mock" for offline demos / smoke tests with no real provider call.
LLM_PATH_MODE=direct-provider

# --- Demo controls -------------------------------------------------------
# Enables POST /admin/demo-reset (clears + re-seeds canonical scenarios).
# Keep "false" in any environment that is not a local demo.
ALLOW_DEMO_RESET=false
